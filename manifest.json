{
  "manifest_version": 3,
  "name": "Baaeed Job Monitor",
  "version": "1.0.0",
  "description": "Monitor Baaeed remote jobs for new listings with جديد badge",
  "permissions": [
    "alarms",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://baaeed.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
